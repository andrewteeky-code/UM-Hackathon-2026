import pandas as pd
import json
from datetime import datetime
from crewai import Agent, Task, Crew, Process

# ==========================================
# PHASE 1: INCOMING FRONTEND VARIABLES
# ==========================================
current_date = datetime.now().strftime("%Y-%m-%d")
user_query = "What should I restock for next week?"
inventory_file = "Grocery_Inventory_and_Sales_Dataset.csv"

print("--- PHASE 1: RECEIVING DATA ---")
print(f"Date: {current_date} | Query: '{user_query}'\n")

# ==========================================
# PHASE 2: CONTEXT INJECTION (YOUR JOB)
# ==========================================
# 1. Read the spreadsheet the user uploaded
try:
    df = pd.read_csv(inventory_file)
except FileNotFoundError:
    print(f"Error: Could not find {inventory_file}. Make sure it is in the same folder.")
    exit()

# Let's take just the first item from the dataset as an example to process
row = df.iloc[0]

# 2. Map the spreadsheet columns to your STANDARDIZED VARIABLES
item_name = row['Product_Name']
current_stock = int(row['Stock_Quantity'])
reorder_threshold = int(row['Reorder_Level'])
supplier_contact = row['Supplier_Name'] + "@supplier.com" # Mocking an email

print(f"--- PHASE 2: PREPARING CONTEXT FOR AI ---")
print(f"Item: {item_name} | Stock: {current_stock} | Threshold: {reorder_threshold}\n")


# ==========================================
# PHASE 3: CREW AI MODELLING (YOUR PROMPT ENGINEERING)
# ==========================================

# 1. The Master Prompt (Agent Backstory)
system_prompt = f"""You are an elite inventory manager for a Malaysian SME retail store.
Today's date is {current_date}.
Your core logic:
1. Compare 'current_stock' against 'reorder_threshold'.
2. If current_stock is STRICTLY LESS THAN reorder_threshold, action MUST be "reorder".
3. If "reorder", draft a polite email to 'supplier_contact' requesting enough units to double the threshold limit.
4. If stock is fine, action is "none" and draft_message is empty.
"""

# 2. Define the Zhipu/CrewAI Agent
inventory_agent = Agent(
    role='Inventory Decision Engine',
    goal='Make strict, mathematical restocking decisions and output ONLY valid JSON.',
    backstory=system_prompt,
    verbose=False,
    allow_delegation=False
    # llm=zhipu_llm  <-- THIS IS WHERE THE API PERSON CONNECTS ZHIPU AI
)

# 3. Define the Task (Injecting the specific item variables)
decision_task = Task(
    description=(
        f"USER QUERY: {user_query}\n\n"
        f"DATA POINT:\n"
        f"- item_name: {item_name}\n"
        f"- current_stock: {current_stock}\n"
        f"- reorder_threshold: {reorder_threshold}\n"
        f"- supplier_contact: {supplier_contact}\n\n"
        "Based on your instructions, make a decision for this specific item."
    ),
    expected_output=(
        "You must return ONLY a raw JSON object with absolutely no markdown wrapping, no ```json tags, and no conversational text. "
        "It must use exactly these variables:\n"
        "{\n"
        '  "recommended_action": "reorder" | "discount" | "none",\n'
        '  "draft_message": "your drafted text here"\n'
        "}"
    ),
    agent=inventory_agent
)

# 4. Assemble the Crew
inventory_crew = Crew(
    agents=[inventory_agent],
    tasks=[decision_task],
    process=Process.sequential
)

# ==========================================
# PHASE 4: EXECUTION & AGENTIC HANDOFF
# ==========================================
print("--- PHASE 3: AI PROCESSING (CREW AI) ---")
print("Sending exact variables to the Agent...\n")

# Fire the Crew (This generates the ai_raw_response)
# Note: Since we don't have the API key plugged in right now, I will mock the 
# ai_raw_response exactly how CrewAI would output it based on the data.
# In production, this line is: ai_raw_response = inventory_crew.kickoff()

# MOCKING THE AI RESPONSE (Because Sushi Rice stock is 22, and threshold is 72)
ai_raw_response = '{"recommended_action": "reorder", "draft_message": "Dear Jaxnation, we are currently low on Sushi Rice. Please send 144 units to our warehouse as soon as possible."}'

print(f"Raw AI Output Received:\n{ai_raw_response}\n")

# THE HANDOFF: We parse your JSON so the Agentic Logic team can use it!
try:
    ai_decision = json.loads(ai_raw_response)
    
    recommended_action = ai_decision.get("recommended_action")
    draft_message = ai_decision.get("draft_message")
    
    print("--- PHASE 4: AGENTIC LOGIC HANDOFF (SUCCESS) ---")
    print(f"Trigger Tool: {recommended_action.upper()} API")
    print(f"Payload to send to {supplier_contact}:\n '{draft_message}'")
    
except json.JSONDecodeError:
    print("ERROR: AI hallucinated and did not return valid JSON. Tweak the prompt!")
