# ============================================================
# UNIVERSAL SCHEMA ADAPTER
# Translates any retail CSV column names into the
# standardised context variable names used by all teams.
# Add new aliases here whenever a new dataset format is added.
# ============================================================

FIELD_SCHEMA = {
    # STD VAR: item_name
    "item_name": {
        "aliases": [
            "product_name", "item description", "item_description",
            "product id", "product_id", "category", "series"
        ],
        "required": True,
    },
    # STD VAR: current_stock
    "current_stock": {
        "aliases": [
            "stock_quantity", "inventory level", "inventory_level",
            "volume", "volume_sa", "retail sales", "retail_sales", "sales"
        ],
        "required": True,
        "cast": float,
    },
    # STD VAR: reorder_threshold
    "reorder_threshold": {
        "aliases": [
            "reorder_level", "reorder level",
            "units ordered", "units_ordered",
            "warehouse sales", "warehouse_sales"
        ],
        "required": False,   # auto-estimated if column is absent
        "cast": float,
    },
    # Used to build STD VAR: supplier_contact
    "supplier_name": {
        "aliases": [
            "supplier_name", "supplier", "store id", "store_id", "region"
        ],
        "required": False,
    },
    # Supporting fields (passed to AI for richer context)
    "product_id": {
        "aliases": ["product_id", "product id", "item code", "item_code"],
        "required": False,
    },
    "category": {
        "aliases": ["catagory", "category", "item type", "item_type"],
        "required": False,
    },
    "status": {
        "aliases": ["status"],
        "required": False,
    },
    "units_sold": {
        "aliases": [
            "sales_volume", "units sold", "units_sold",
            "demand", "retail sales", "retail_sales"
        ],
        "required": False,
        "cast": float,
    },
    "date": {
        "aliases": ["date", "last_order_date", "date_received"],
        "required": False,
    },
}


def normalise_columns(df: pd.DataFrame) -> dict:
    """
    Returns {logical_field: actual_csv_column} by matching
    FIELD_SCHEMA aliases against the DataFrame columns
    (case-insensitive, whitespace-stripped).
    """
    col_lower = {c.lower().strip(): c for c in df.columns}
    mapping = {}
    for field, meta in FIELD_SCHEMA.items():
        for alias in meta["aliases"]:
            if alias.lower() in col_lower:
                mapping[field] = col_lower[alias.lower()]
                break
    return mapping


def extract_context_variables(row: pd.Series, col_map: dict, df: pd.DataFrame) -> dict:
    """
    Produces a dict of all standardised context variables
    (item_name, current_stock, reorder_threshold, supplier_contact, …)
    from a single dataset row.
    """
    ctx = {}

    for field, meta in FIELD_SCHEMA.items():
        col = col_map.get(field)
        raw = row[col] if col else None

        if raw is not None and "cast" in meta:
            try:
                raw = meta["cast"](str(raw).replace("$", "").replace(",", "").strip())
            except (ValueError, TypeError):
                raw = None

        ctx[field] = raw

    # ── Fallback: estimate reorder_threshold from dataset median ──
    if ctx.get("reorder_threshold") is None:
        stock_col = col_map.get("current_stock")
        if stock_col:
            median_stock = df[stock_col].apply(
                lambda x: float(str(x).replace("$", "").replace(",", "").strip())
                if str(x).replace("$", "").replace(",", "").strip().replace(".", "").isdigit()
                else None
            ).dropna().median()
            ctx["reorder_threshold"] = round(median_stock * 0.6, 2)
            ctx["_threshold_estimated"] = True
        else:
            ctx["reorder_threshold"] = 0.0
            ctx["_threshold_estimated"] = True

    # ── STD VAR: supplier_contact ──────────────────────────────────
    # Built from supplier_name. Replace with a real contacts lookup
    # table or CRM API call in production.
    supplier = ctx.get("supplier_name") or "unknownsupplier"
    ctx["supplier_contact"] = f"{str(supplier).lower().replace(' ', '')}@supplier.com"

    return ctx


def load_and_detect(filepath: str):
    """
    Loads any retail/inventory CSV and returns (df, col_map, schema_name).
    Raises ValueError if required STD VARs cannot be mapped.
    """
    try:
        df = pd.read_csv(filepath)
    except FileNotFoundError:
        raise FileNotFoundError(f"File not found: {filepath}")

    col_map = normalise_columns(df)

    missing = [f for f, m in FIELD_SCHEMA.items()
               if m["required"] and f not in col_map]
    if missing:
        raise ValueError(
            f"Cannot map required fields {missing} from columns: {list(df.columns)}"
        )

    cols_lower = [c.lower() for c in df.columns]
    if "product_name" in cols_lower:
        schema_name = "Grocery Inventory Dataset"
    elif "inventory level" in cols_lower:
        schema_name = "Multi-Store Sales Dataset"
    elif "item description" in cols_lower or "item code" in cols_lower:
        schema_name = "Warehouse & Retail Sales Dataset"
    elif "series" in cols_lower and "volume" in cols_lower:
        schema_name = "IO/WRT Time Series Dataset"
    else:
        schema_name = "Unknown Retail Dataset"

    return df, col_map, schema_name


# ============================================================
# PHASE 2 — CONTEXT VARIABLES
# (Extracted & standardised from inventory_file)
# ============================================================
print("\n" + "=" * 62)
print("PHASE 2 — CONTEXT VARIABLES")
print("=" * 62)

df, col_map, schema_name = load_and_detect(inventory_file)

print(f"  Schema detected   : {schema_name}")
print(f"  Rows              : {len(df):,}  |  Columns: {len(df.columns)}")

# ── Process the first row (swap iloc[0] for any row, or loop for batch) ──
row = df.iloc[0]
ctx = extract_context_variables(row, col_map, df)

# ── Assign to the exact STD VAR names ─────────────────────────────────────
item_name         = ctx["item_name"]          # STD VAR: item_name
current_stock     = ctx["current_stock"]      # STD VAR: current_stock
reorder_threshold = ctx["reorder_threshold"]  # STD VAR: reorder_threshold
supplier_contact  = ctx["supplier_contact"]   # STD VAR: supplier_contact

print(f"\n  item_name          = {item_name}")
print(f"  current_stock      = {current_stock}")
print(f"  reorder_threshold  = {reorder_threshold}", end="")
print("  ⚠️  (estimated — no threshold column found)" if ctx.get("_threshold_estimated") else "")
print(f"  supplier_contact   = {supplier_contact}")


# ============================================================
# PHASE 3 — AI LAYER  (Z.ai — official SDK: pip install zai-sdk)
# Docs : https://docs.z.ai/guides/overview/quick-start
# Model: glm-4.7 (default) or glm-5.1
# ============================================================
print("\n" + "=" * 62)
print("PHASE 3 — AI LAYER  (Z.ai)")
print("=" * 62)

# STD VAR: system_prompt
system_prompt = f"""You are an elite inventory manager for a Malaysian SME retail store.
Today's date is {current_date}.

Decision rules:
1. Compare current_stock against reorder_threshold.
2. If current_stock < reorder_threshold  →  recommended_action = "reorder"
   Draft a polite supplier email to supplier_contact requesting
   enough stock to DOUBLE the reorder_threshold.
3. If current_stock is high but units_sold is low  →  recommended_action = "discount"
   Draft a short internal memo recommending a markdown promotion.
4. If stock is healthy  →  recommended_action = "none"
   draft_message must be an empty string.

IMPORTANT: Return ONLY a raw JSON object — no markdown, no ```json fences, no extra text.
Schema: {{ "item_name": str, "recommended_action": "reorder"|"discount"|"none", "reason": str, "draft_message": str }}

Dataset schema in use: {schema_name}
"""

user_message = (
    f"USER QUERY: {user_query}\n\n"
    f"ITEM DATA:\n"
    f"  item_name          : {item_name}\n"
    f"  current_stock      : {current_stock}\n"
    f"  reorder_threshold  : {reorder_threshold}\n"
    f"  supplier_contact   : {supplier_contact}\n"
    f"  category           : {ctx.get('category')}\n"
    f"  units_sold         : {ctx.get('units_sold')}\n"
    f"  status             : {ctx.get('status')}\n\n"
    f"Make a restocking decision for this item."
)

print(f"  Calling Z.ai ({ZAI_MODEL})...")

# ── Z.ai API call ──────────────────────────────────────────────────────────
try:
    zai_client = ZaiClient(api_key=ZAI_API_KEY)

    response = zai_client.chat.completions.create(
        model=ZAI_MODEL,
        messages=[
            {"role": "system", "content": system_prompt},   # STD VAR: system_prompt
            {"role": "user",   "content": user_message},
        ],
        temperature=0.1,    # low temp = consistent, deterministic JSON output
        max_tokens=1000,
    )

    # STD VAR: ai_raw_response — exact unedited text from Z.ai
    ai_raw_response = response.choices[0].message.content

except zai.core.APIStatusError as e:
    print(f"  Z.ai API error    : {e}")
    ai_raw_response = '{"recommended_action":"none","draft_message":"","reason":"API error."}'
except zai.core.APITimeoutError:
    print("  Z.ai request timed out.")
    ai_raw_response = '{"recommended_action":"none","draft_message":"","reason":"Timeout."}'
except Exception as e:
    print(f"  Unexpected error  : {e}")
    ai_raw_response = '{"recommended_action":"none","draft_message":"","reason":"Unexpected error."}'
# ──────────────────────────────────────────────────────────────────────────

print(f"\n  ai_raw_response =\n  {ai_raw_response}\n")


# ============================================================
# PHASE 4 — AGENTIC HANDOFF
# Parse ai_raw_response into the final STD output variables.
# ============================================================
print("=" * 62)
print("PHASE 4 — AGENTIC HANDOFF")
print("=" * 62)

try:
    # Strip accidental ```json fences if the model adds them despite instructions
    _clean = ai_raw_response.strip().removeprefix("```json").removeprefix("```").removesuffix("```").strip()
    _parsed = json.loads(_clean)

    recommended_action = _parsed.get("recommended_action", "none")  # STD VAR: recommended_action
    draft_message      = _parsed.get("draft_message", "")           # STD VAR: draft_message
    _reason            = _parsed.get("reason", "")

    print(f"  recommended_action  = \"{recommended_action}\"")
    print(f"  reason              = {_reason}")
    print(f"\n  → Trigger API       : {recommended_action.upper()} WORKFLOW")

    if draft_message:
        print(f"\n  draft_message (to: {supplier_contact}):\n")
        print("  " + "\n  ".join(draft_message.splitlines()))
    else:
        print(f"\n  draft_message       = \"\"  (no action needed)")

except json.JSONDecodeError:
    print("  ERROR: ai_raw_response is not valid JSON.")
    print("  Raw output was:", ai_raw_response)
    print("  Fix: Tighten system_prompt or lower temperature.")

print("\n" + "=" * 62)
print("PIPELINE COMPLETE")
print("=" * 62)
